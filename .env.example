# Environment API location used by inference runners
ENV_BASE_URL=http://127.0.0.1:8000

# Backend CORS policy (comma-separated origins, or * for all)
ALLOWED_ORIGINS=http://localhost:5173

# Optional deterministic seed override for runs
# RUN_SEED=42

# Live dashboard controls
LIVE_DASHBOARD_ALLOW_APPLY=true
# Agent control mode: heuristic or rl
AGENT_CONTROL_MODE=heuristic
# RL policy artifact path (used when AGENT_CONTROL_MODE=rl)
RL_POLICY_PATH=cloud_cost_env/data/rl/q_policy_v1.json
# Azure secure-connect approval token lifetime (seconds)
AZURE_APPROVAL_WINDOW_SECONDS=600

# Production runtime controls
LOG_LEVEL=INFO
FORWARDED_ALLOW_IPS=*
UVICORN_WORKERS=1

# Per-IP rate limits (requests per RATE_LIMIT_WINDOW_SECONDS)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_RESET_PER_WINDOW=60
RATE_LIMIT_STEP_PER_WINDOW=180
RATE_LIMIT_LIVE_ACTION_PER_WINDOW=60
RATE_LIMIT_AZURE_APPROVAL_PER_WINDOW=30
RATE_LIMIT_AZURE_CONNECT_PER_WINDOW=6

# Optional metadata shown in live dashboard payload
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
# AWS_ACCOUNT_ARN=arn:aws:iam::123456789012:root

# LLM credentials (provide one of these)
# HF_TOKEN=your_huggingface_router_token
# API_KEY=your_openai_compatible_api_key
# OPENAI_API_KEY=your_openai_api_key

# LLM model + endpoint
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
API_BASE_URL=https://router.huggingface.co/v1
# Legacy alias still accepted by runner:
# LLM_API_BASE_URL=https://router.huggingface.co/v1

# Inference behavior controls
ALLOW_HEURISTIC_FALLBACK=true
STRICT_ACTION_MODE=false

# Optional generation controls for LLM runner
MAX_STEPS=8
TEMPERATURE=0.3
MAX_TOKENS=300
